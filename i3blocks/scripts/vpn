#!/bin/sh

_output=$(sudo wg show wg-mullvad transfer 2>/dev/null);

if [[ $? -ne 0 ]]; then
	echo "no vpn";
	exit 33;
fi

_down=$(echo "$_output" | cut -f2 | numfmt --to=iec-i --suffix=B --format="%9.2f")
_up=$(echo "$_output" | cut -f3 | numfmt --to=iec-i --suffix=B --format="%9.2f")

printf "¯¬Ü %s ¯¬í %s\n" $_down $_up
