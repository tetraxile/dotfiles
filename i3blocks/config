# i3blocks configuration file

# Global properties
command=$SCRIPT_DIR/$BLOCK_NAME
separator=true
separator_block_width=15
markup=pango

[wifi]
command=iwgetid -r
interval=5
label=<span color="#ff79c6"> </span>
instance=wlp2s0

[keyboard]
interval=once
signal=1

[volume]
interval=once
signal=2

[brightness]
interval=once
signal=3

[battery]
interval=2

[timezone]
interval=5

[datetime]
interval=1
